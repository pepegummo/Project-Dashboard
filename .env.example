# ══════════════════════════════════════════════════════════════════════════════
#  CPF Dashboard — Environment Variables
#  Copy this file to .env and fill in the values before running.
#
#  Usage:
#    Local dev (npm run dev)  →  use localhost URLs below
#    Docker Compose           →  docker compose handles internal hostnames
#                                automatically; you only need to change
#                                passwords, JWT_SECRET, and optional ports.
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL / TimescaleDB ─────────────────────────────────────────────────
POSTGRES_USER=iot_user
POSTGRES_PASSWORD=iot_password
POSTGRES_DB=iot_dashboard

# Used by the backend directly (local dev) and by Prisma CLI tools.
# ⚠  In Docker Compose this is OVERRIDDEN automatically to use
#    the internal hostname "db" — you do not need to change this for Docker.
DATABASE_URL=postgresql://iot_user:iot_password@localhost:5432/iot_dashboard

# Host port to publish the database on (default 5432)
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
# ⚠  In Docker Compose this is overridden to redis://redis:6379 automatically.
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ─── AI provider (OpenAI-compatible chat completions) ────────────────────────
# Required for the AI Assistant chat feature (IotVision AI).
# Works with any OpenAI-compatible provider; defaults target Groq.
# AI_API_KEY is preferred; GROQ_API_KEY still works as a fallback.
AI_API_KEY=gsk_...
# Full chat-completions endpoint. Default: https://api.groq.com/openai/v1/chat/completions
#AI_BASE_URL=
# Main chat model. Default: openai/gpt-oss-120b
#AI_MODEL=
# Small/fast model for intent routing + answer verification. Default: openai/gpt-oss-20b
#AI_ROUTER_MODEL=
# Completion token ceiling (hidden reasoning counts against it). Default: 2048
#AI_MAX_TOKENS=

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# ⚠  CHANGE THIS before deploying. Must be at least 32 characters.
#    Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string-before-deploying-to-prod
JWT_EXPIRES_IN=24h

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origin(s) the backend allows requests from.
# Docker Compose: the browser hits the Nginx frontend, which reverse-proxies
#   /api to the backend on the internal network — so set this to the Nginx URL.
# Local dev: Vite dev server runs on :5173, so keep http://localhost:5173.
CORS_ORIGIN=http://localhost:5173

# ─── Backend port ─────────────────────────────────────────────────────────────
BACKEND_PORT=4000    # REST API + WebSocket (/ws)

# ─── Frontend build (Vite) ────────────────────────────────────────────────────
# ⚠  These are BAKED INTO the JS bundle at build time — not runtime!
#
#  Docker Compose (default):
#    VITE_API_URL=""          → axios uses relative URL /api (works on any host)
#    VITE_WS_URL="ws://localhost:5173/ws"  → Nginx proxies /ws → backend:4000
#
#  Local dev (npm run dev):
#    VITE_API_URL=http://localhost:4000   (or leave blank, Vite proxy handles it)
#    VITE_WS_URL=ws://localhost:4000/ws   (same port as REST, via Vite proxy)
#
#  Production with a real domain (e.g. dashboard.example.com):
#    VITE_API_URL=""
#    VITE_WS_URL=wss://dashboard.example.com/ws
VITE_API_URL=
VITE_WS_URL=ws://localhost:5173/ws

# ─── Frontend port ────────────────────────────────────────────────────────────
FRONTEND_PORT=5173

# ─── pgAdmin (optional, start with: docker compose --profile tools up -d) ────
PGADMIN_EMAIL=admin@cpf.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
